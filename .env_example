# ═══ 基本配置 ═══
APP_NAME=interactive-bot
BOT_TOKEN=1234567890:REPLACE_WITH_YOUR_TELEGRAM_BOT_TOKEN
BOT_USERNAME=your_bot_username

# ═══ 管理配置 ═══
ADMIN_GROUP_ID=-1001234567890
ADMIN_USER_IDS=123456789,987654321

# ═══ 默认 LLM 配置 ═══
# 支持 OpenAI / DeepSeek / Ollama / 任何 OpenAI 兼容 API
# 这些值会作为机器人后台「AI 设置」的初始默认配置。
# 启动后可在 Telegram 机器人内新增多个 AI、选择首位模型；首位失败会自动切换备用 AI。
# Ollama 本地: http://localhost:11434/v1
# DeepSeek:    https://api.deepseek.com/v1
# OpenAI:      https://api.openai.com/v1
# 第三方中转:   https://your-proxy.com/v1
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat

# ═══ 风控配置 ═══
BLACKLIST_USER_IDS=
RATE_LIMIT_PER_MINUTE=10
MESSAGE_INTERVAL=5
DISABLE_CAPTCHA=FALSE

# ═══ 功能开关 ═══
DELETE_TOPIC_AS_FOREVER_BAN=FALSE
DELETE_USER_MESSAGE_ON_CLEAR_CMD=TRUE
WELCOME_MESSAGE="欢迎来到白猫工作室 (Web3Baimao) ⚡️\n我是您的 AI 客服助手，很高兴为您服务！\n\n我们提供专业的智能机器人定制开发、智能合约定制与安全审计、Web3社区矩阵系统搭建等服务。\n\n💡 如需人工客服，点击下方按钮即可呼叫主理人喔。"
